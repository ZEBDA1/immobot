BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
DATABASE_URL=sqlite:///data.db
# Optional outbound HTTP proxy for scraping (http://user:pass@host:port or socks5h://...)
PROXY_URL=
# Free plan delay before sending alerts (seconds)
PREMIUM_FREE_DELAY_SECONDS=300
# Enable Nominatim geocoding for radius filtering (true/false)
ENABLE_GEOCODING=false
# Nominatim user agent (required if ENABLE_GEOCODING=true)
GEOCODING_USER_AGENT=immobot/1.0 (contact@example.com)