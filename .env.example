BOT_TOKEN=VOTRE_TOKEN_ICI
DATABASE_URL=sqlite:///data.db
PROXY_URL=FORMAT: http://USER:PASS@HOST:PORT
PROXY_FALLBACK_DIRECT=true
PREMIUM_FREE_DELAY_SECONDS=300
DEFAULT_SOURCE_QUOTA=5
SOURCE_QUOTA_PER_CYCLE=paruvendu=6,entreparticuliers=6,leboncoin=3,seloger=3,pap=4,logicimmo=4,rentola=4,ouestfranceimmo=4
PER_SOURCE_CONCURRENCY=4
SCRAPER_TASK_TIMEOUT_SECONDS=20
# When true, ignore per-source quotas and scan all locations per cycle.
# Leave false by default to reduce rate-limit risks.
FULL_SCAN=false
EXPAND_LOCATION_VARIANTS=true
INCLUDE_GENERIC_LOCATION_PASS=true

# Geocoding
ENABLE_GEOCODING=false
GEOCODING_USER_AGENT=immobot/1.0 (contact@example.com)

# Comma-separated Telegram user IDs with admin access
ADMIN_TELEGRAM_IDS=VOTRE_ID_TELEGRAM_ICI

# Optional SeLoger experimental mode
SELOGER_COOKIE=
SELOGER_USER_AGENT=

# Optional manual cookies for blocked sources
PAP_COOKIE=
LEBONCOIN_COOKIE=

# Selenium fallback for blocked pages (slower but can improve success rate)
USE_SELENIUM_FALLBACK=false

# Optional AI scam analysis (disabled by default)
AI_SCAM_ENABLED=false
AI_SCAM_ENDPOINT=
AI_SCAM_API_KEY=
AI_SCAM_MODEL=gpt-4o-mini
AI_SCAM_TIMEOUT=12
